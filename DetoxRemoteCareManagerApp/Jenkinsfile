pipeline {
	agent any
	environment {
		GOOGLE_APPLICATION_CREDENTIALS = credentials('google-application-credentials')
		GRADLE_PROPERTIES_DEV = credentials('general-detoxrcm-dev-gradle-properties')
		GRADLE_PROPERTIES_PROD = credentials('general-detoxrcm-prod-gradle-properties')
	}
	stages {
		stage('Deploy to development') {
			when {
				branch 'jenkins-general-detoxrcm-dev'
			}
			steps {
				dir('git/detox-remote-care-manager') {
					sh 'mv `ls -d ../../* | grep -v "\\.\\./\\.\\./git"` .'
				}
				dir('git/rrd-utils') {
					git url: 'https://github.com/RoessinghResearch/rrd-utils.git'
				}
				dir('git/detox-remote-care-manager/DetoxRemoteCareManagerApp') {
					sh 'cp $GRADLE_PROPERTIES_DEV . && \
						cp $GOOGLE_APPLICATION_CREDENTIALS google-application-credentials.json && \
						chmod 755 gradlew && \
						./gradlew dockerBuild dockerStart'
				}
			}
		}
		stage('Deploy to production') {
			when {
				branch 'jenkins-general-detoxrcm-prod'
			}
			steps {
				dir('git/detox-remote-care-manager') {
					sh 'mv `ls -d ../../* | grep -v "\\.\\./\\.\\./git"` .'
				}
				dir('git/rrd-utils') {
					git url: 'https://github.com/RoessinghResearch/rrd-utils.git'
				}
				dir('git/detox-remote-care-manager/DetoxRemoteCareManagerApp') {
					sh 'cp $GRADLE_PROPERTIES_PROD . && \
						cp $GOOGLE_APPLICATION_CREDENTIALS google-application-credentials.json && \
						chmod 755 gradlew && \
						./gradlew dockerBuild'
				}
				dir('git/detox-remote-care-manager/DetoxRemoteCareManagerApp') {
					sh 'dockerTag=`grep "^dockerTag=" gradle.properties | tr -d "\r\n" | sed -e "s/^dockerTag=//"` && \
						./gradlew buildDockerCompose && \
						scp -r build/docker-compose jenkins@${DETOXRCM_PROD_HOST}:~ && \
						docker save -o detoxrcm_docker_images.tar \
						detoxrcm-tomcat:$dockerTag detoxrcm-web:$dockerTag \
						phpmyadmin:fpm-alpine mariadb:11 && \
						scp detoxrcm_docker_images.tar jenkins@${DETOXRCM_PROD_HOST}:~'
				}
				dir('git/detox-remote-care-manager/DetoxRemoteCareManagerApp') {
					sh 'dockerProject=`grep "^dockerProject=" gradle.properties | tr -d "\r\n" | sed -e "s/^dockerProject=//"` && \
						ssh jenkins@${DETOXRCM_PROD_HOST} \
						"docker load --input detoxrcm_docker_images.tar && \
						cd docker-compose && \
						docker compose -p $dockerProject up -d && \
						docker image prune -f && \
						docker buildx prune -f"'
				}
			}
		}
	}
	post {
		success {
			deleteDir()
		}
	}
}
